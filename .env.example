# ============================================================
# LLM 配置（通义千问，阿里云百炼平台）
# 前往 https://bailian.console.aliyun.com/ 创建 API Key
# ============================================================
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 可选：qwen-turbo（最快最省钱）/ qwen-plus（均衡，默认）/ qwen-max（最强）
QWEN_MODEL=qwen-plus

# ============================================================
# Lark (Feishu) 应用凭证
# 在飞书开放平台 https://open.feishu.cn 创建企业自建应用后获取
# ============================================================
LARK_APP_ID=cli_xxxxxxxxxxxxxxxx
LARK_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================
# Lark Bitable 多维表格 ID 配置
# 从 Bitable 页面 URL 中提取：
#   https://xxx.feishu.cn/base/{BASE_ID}?table={TABLE_ID}
# ============================================================

# AI 秘书调度状态库
BITABLE_BASE_ID=xxxxxxxxxxxxxxxxxxxxxxx

# 功能表
BITABLE_TABLE_FEATURE=tblxxxxxxxxxxxxxxxx

# 群组拉取游标与动态调度表
BITABLE_TABLE_CURSOR=tblxxxxxxxxxxxxxxxx

# 待补全话题池（追问未闭环的 Thread）
BITABLE_TABLE_PENDING_THREADS=tblxxxxxxxxxxxxxxxx

# Bitable 应用 Token（与 BITABLE_BASE_ID 相同，供 main.py 的 write_threads_to_bitable 使用）
BITABLE_APP_TOKEN=xxxxxxxxxxxxxxxxxxxxxxx

# 群组默认同步间隔（分钟），影响 Cursor 表「下次同步时间」计算，默认 60
DEFAULT_SYNC_INTERVAL_MINUTES=60

# 话题主表 ID（信息纠正写入目标表，与周报话题表相同）
BITABLE_TABLE_ID=tblKscoaGp6VwhQe

# ============================================================
# 信息纠正模块（飞书卡片回复自动触发）
# ============================================================

# 允许触发信息纠正的用户 open_id（逗号分隔，留空则不限制用户）
# 在飞书开放平台 → 用户管理 中查看用户 open_id
AUTHORIZED_USER_IDS=ou_xxxxxxxxxxxxxxxx

# ============================================================
# AI 秘书问答模块（@机器人 查询）
# ============================================================

# 问答日志表 ID（已自动创建）
BITABLE_TABLE_QA_LOG=tblwhuGWDRPpAyPp

# 功能表 ID（默认已配置）
BITABLE_TABLE_FEATURES=tblLzX7wqGWFr9KP

# 模块表 ID（默认已配置）
BITABLE_TABLE_MODULES=tblaDW4D2hQS2xCw

# Meegle 缺陷表 ID（默认已配置）
BITABLE_TABLE_MEEGLE_DEFECTS=tblLmzknrXtzhGFc

# Meegle 任务表 ID（默认已配置）
BITABLE_TABLE_MEEGLE_TASKS=tblzyH3DKSz9IAG9

# Meegle 需求表 ID（默认已配置）
BITABLE_TABLE_MEEGLE_REQS=tblO4wA2agKU1ZSP

# 问答缓存有效期（小时，默认 24）
QA_CACHE_TTL_HOURS=24

# 缓存语义相似度阈值 0~1（默认 0.85，越高越严格）
QA_SIMILARITY_THRESHOLD=0.85

# ============================================================
# Meegle 配置（前往 meegle.com 开发者设置中获取）
# ============================================================
MEEGLE_PLUGIN_ID=MII_xxxxxxxxxxxxxxxx
MEEGLE_PLUGIN_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MEEGLE_USER_KEY=xxxxxxxxxxxxxxxxxxxx
MEEGLE_PROJECT_KEY=xxxxxx

# ============================================================
# Railway 定时启停（部署后填入，通过 scripts/get_railway_ids.py 获取）
# ============================================================
RAILWAY_API_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RAILWAY_SERVICE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
RAILWAY_ENVIRONMENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
