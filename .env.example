# ============================================================
# Lark (Feishu) 应用凭证
# 在飞书开放平台 https://open.feishu.cn 创建企业自建应用后获取
# ============================================================
LARK_APP_ID=cli_xxxxxxxxxxxxxxxx
LARK_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================
# Lark Bitable 多维表格 ID 配置
# 从 Bitable 页面 URL 中提取：
#   https://xxx.feishu.cn/base/{BASE_ID}?table={TABLE_ID}
# ============================================================

# AI 秘书调度状态库（用于 Cursor 表 + Pending Threads 表）
BITABLE_BASE_ID=xxxxxxxxxxxxxxxxxxxxxxx

# 群组拉取游标与动态调度表
BITABLE_TABLE_CURSOR=tblxxxxxxxxxxxxxxxx

# 待补全话题池（追问未闭环的 Thread）
BITABLE_TABLE_PENDING_THREADS=tblxxxxxxxxxxxxxxxx
