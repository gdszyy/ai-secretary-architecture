# XPBET 全球站功能地图管理系统 - 环境变量配置
# 复制此文件为 .env 并填入实际值

# ==================== 数据源模式 ====================

# 是否使用静态 JSON 数据（开发/演示模式）
# true  = 使用本地静态 JSON 文件（无需飞书 API 凭证）
# false = 从飞书 Bitable API 实时拉取（需要配置下方凭证）
VITE_USE_STATIC_DATA=false

# ==================== 飞书 API 配置 ====================
# 仅在 VITE_USE_STATIC_DATA=false 时需要配置

# 飞书应用 App ID（在飞书开放平台创建应用后获取）
# 应用需要开通权限：bitable:app:readonly
VITE_FEISHU_APP_ID=

# 飞书应用 App Secret（请妥善保管，不要提交到版本控制）
VITE_FEISHU_APP_SECRET=

# ==================== 多维表格配置（通常无需修改）====================

# 多维表格 Base ID（来自飞书多维表格 URL）
# 当前值：CyDxbUQGGa3N2NsVanMjqdjxp6e（已内置在代码中）
# VITE_BITABLE_BASE_ID=CyDxbUQGGa3N2NsVanMjqdjxp6e

# 模块表 Table ID
# 当前值：tblaDW4D2hQS2xCw（已内置在代码中）
# VITE_MODULE_TABLE_ID=tblaDW4D2hQS2xCw

# 功能表 Table ID
# 当前值：tblLzX7wqGWFr9KP（已内置在代码中）
# VITE_FEATURE_TABLE_ID=tblLzX7wqGWFr9KP
